0 LET S=0 : LET Z=0 : DIM A$(20) : DIM Q$(20)
5 PRINT : PRINT
10 PRINT "HIGH-LOW / BY LANDON SMITH"
15 PRINT "----------------------------"

20 LET U=RND(13)+1  : REM YOUR CARD
25 LET C=RND(13)+1  : REM COMPUTER CARD

30 PRINT : PRINT "YOUR CARD IS:";U
35 PRINT "IS MY CARD HIGHER OR LOWER"; : INPUT A$

36 IF A$="HIGHER" THEN GOTO 50
37 IF A$="LOWER" THEN GOTO 50
38 PRINT "I DON'T UNDERSTAND!" : GOTO 35

50 REM CHECK RESULT
51 IF A$="HIGHER" AND C>U THEN GOSUB 200
52 IF A$="HIGHER" AND C<U THEN GOSUB 210
53 IF A$="HIGHER" AND C=U THEN GOSUB 220
54 IF A$="LOWER" AND C<U THEN GOSUB 200
55 IF A$="LOWER" AND C>U THEN GOSUB 210
56 IF A$="LOWER" AND C=U THEN GOSUB 220

60 PRINT "MY CARD WAS:";C : PRINT "YOUR SCORE:";S
65 PRINT : PRINT "WANNA PLAY AGAIN (YES/NO)"; : INPUT Q$
70 IF Q$="YES" THEN GOTO 20
75 IF Q$="NO" THEN GOTO 799
80 PRINT "I DON'T UNDERSTAND!" : GOTO 65

200 REM YOU WIN
205 PRINT "YOU WIN THIS ROUND!"
206 LET S=S+1
207 LET Z=Z+1
208 IF Z>2 THEN LET S=S+1 : PRINT "WIN STREAK BONUS!"
209 RETURN

210 REM YOU LOSE
215 PRINT "YOU LOSE THIS ROUND!"
216 LET S=S-1
217 LET Z=0
218 RETURN

220 REM TIE
225 PRINT "WE HAVE THE SAME CARD! NO POINTS"
226 RETURN

799 PRINT : PRINT "GOODBYE."
800 END